<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.leolost2605.emergency-alerts</id>

  <name>Emergency Alerts</name>
  <name xml:lang="uk">Надзвичайні сповіщення</name>
  <summary>Receive emergency alerts</summary>
  <summary xml:lang="uk">Отримуйте сповіщення про надзвичайні ситуації</summary>

  <metadata_license>CC-BY-4.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Emergency Alerts is a simple app that sends you alerts for your locations. Supported countries include Germany, the US (only weather alerts) and Ukraine (only air raid alerts) with more countries coming soon!
    </p>
    <p xml:lang="uk">
      «Надзвичайні сповіщення» — це простий застосунок, який надсилає попередження для обраних вами місць. Наразі підтримуються Німеччина, США (лише погодні попередження) та Україна (лише повітряні тривоги). Незабаром з’являться й інші країни!
    </p>
    <p>Features:</p>
    <p xml:lang="uk">Можливості:</p>
      <ul>
        <li>Receive flood and weather warnings</li>
        <li xml:lang="uk">Отримуйте попередження про негоду та повені</li>
        <li>Receive alerts from your local civil protection authority</li>
        <li xml:lang="uk">Отримуйте сповіщення від місцевих служб цивільного захисту</li>
        <li>Quickly view alerts for your favorite locations on the dashboard</li>
        <li xml:lang="uk">Швидкий перегляд сповіщень для улюблених місць на панелі</li>
        <li>View alerts from all over the world on the map</li>
        <li xml:lang="uk">Переглядайте сповіщення з усього світу на мапі</li>
        <li>Get notifications when new alerts are issued for your saved locations</li>
        <li xml:lang="uk">Дізнавайтеся про нові загрози для збережених місць</li>
        <li>Support for Germany, the US (only weather alerts) and Ukraine (only air raid alerts) with more countries coming soon</li>
        <li xml:lang="uk">Підтримка Німеччини, США (лише погодні попередження) та України (лише повітряні тривоги) з майбутнім розширенням списку країн</li>
      </ul>
  </description>

  <developer id="io.github.leolost2605">
    <name>Leonhard</name>
    <name xml:lang="uk">Леонард</name>
  </developer>

  <url type="homepage">https://github.com/leolost2605/emergency-alerts</url>
  <url type="bugtracker">https://github.com/leolost2605/emergency-alerts/issues</url>
  <url type="donation">https://github.com/sponsors/leolost2605</url>
  <url type="contribute">https://github.com/leolost2605/emergency-alerts</url>
  <url type="vcs-browser">https://github.com/leolost2605/emergency-alerts</url>

  <content_rating type="oars-1.1" />
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <recommends>
    <internet>always</internet>
  </recommends>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <launchable type="desktop-id">io.github.leolost2605.emergency-alerts.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#7eb9ed</color>
    <color type="primary" scheme_preference="dark">#032f9c</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://github.com/leolost2605/emergency-alerts/blob/3a6ac5b09a74a34ddd5b3a6df92bdf9a5699a953/data/Screenshots/dashboard.png?raw=true</image>
      <caption>The Dashboard showing active alerts</caption>
      <caption xml:lang="uk">Панель із активними сповіщеннями</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/leolost2605/emergency-alerts/blob/3a6ac5b09a74a34ddd5b3a6df92bdf9a5699a953/data/Screenshots/warning.png?raw=true</image>
      <caption>Detailed information about an alert</caption>
      <caption xml:lang="uk">Докладна інформація про сповіщення</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/leolost2605/emergency-alerts/blob/3a6ac5b09a74a34ddd5b3a6df92bdf9a5699a953/data/Screenshots/map.png?raw=true</image>
      <caption>The map showing active alerts across Germany and Ukraine</caption>
      <caption xml:lang="uk">Мапа активних сповіщень у Німеччині та Україні</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/leolost2605/emergency-alerts/blob/3a6ac5b09a74a34ddd5b3a6df92bdf9a5699a953/data/Screenshots/dashboard-dark.png?raw=true</image>
      <caption>The Dashboard in dark mode</caption>
      <caption xml:lang="uk">Панель у темному режимі</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="2.0.0" date="2026-01-07">
      <description>
        <p>
          This release finally brings the long-awaited weather alerts for the U.S. and air raid alerts for Ukraine. In addition location selection is now more powerful than ever — you can choose any point on Earth — and the new map view lets you see active alerts and affected areas at a glance.
        </p>
        <p>
          To make all this possible, the way locations are stored had to be updated. When you first launch the app after updating, it tries to migrate your existing locations automatically. In rare cases, this may not work and you might need to re-add them manually. If that happens a notification will be sent.
        </p>
        <p>Highlights:</p>
        <ul>
          <li>Weather alerts now available across the U.S.</li>
          <li>Air raid alerts now available for Ukraine</li>
          <li>Pick any point on Earth as a location</li>
          <li>New map view showing active alerts and impacted areas</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2025-10-20">
      <description>
        <p>
          This release is a minor update that fixes some annoying bugs and
          prepares support for an additional country that will be coming soon!
        </p>
        <ul>
          <li>Fixed an issue that caused icons to not appear</li>
          <li>Use libsoup instead of relying on GVFS. This fixes the file system access warning in app stores</li>
          <li>Improved performance for the Germany alert provider</li>
          <li>Added backend support for pushing alerts instead of periodic polling</li>
          <li>Prepares support for an additional country coming soon</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2024-12-28">
      <description>
        <p>The first release of Emergency Alerts!</p>
          <ul>
            <li>Receive flood and weather warnings</li>
            <li>Receive alerts from your local civil protection authority</li>
            <li>Support for multiple locations at once</li>
          </ul>
      </description>
    </release>
  </releases>

</component>
